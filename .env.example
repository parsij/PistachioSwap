VITE_API_BASE_URL=http://localhost:3001
VITE_REOWN_PROJECT_ID=
VITE_DEFAULT_CHAIN_ID=56
VITE_CHAIN_NAME='BNB Chain'
VITE_CHAIN_LOGO=/icons/bnb.svg
VITE_GAS_ASSIST_ENABLED=false
VITE_METAMASK_MULTICHAIN_ENABLED=false
VITE_BSC_PUBLIC_RPC_URL=

# Prefer the backend's cached Uniswap public-subgraph 24h volume catalog in
# the token selector. The existing market catalog remains the fallback.
VITE_USE_UNISWAP_VOLUME_TOKENS=true

# Gas Assist prints redacted step-by-step browser diagnostics automatically in
# development. Set this to true to keep those diagnostics in a production-like build.
# Session tokens, signatures, private keys, and signed raw transactions are never logged.
VITE_DEBUG_SPONSORSHIP_TRACE=false

# Pistachio Wallet is disabled unless both local and passkey flags are true.
# Restart Vite after changing any VITE_* value. Never put wallet secrets,
# passkey output, private RPC credentials, or backend API keys in Vite variables.
VITE_PISTACHIO_LOCAL_WALLET_ENABLED=false
VITE_PISTACHIO_PASSKEY_WALLET_ENABLED=false
VITE_PISTACHIO_WALLET_IMPORT_ENABLED=false
VITE_PISTACHIO_WALLET_KEYSTORE_IMPORT_ENABLED=false
VITE_PISTACHIO_PASSKEY_DIAGNOSTICS=false
VITE_PISTACHIO_WALLET_AUTO_LOCK_MINUTES=15
# Optional. Must exactly match the explicitly approved staging hostname.
VITE_PISTACHIO_PASSKEY_STAGING_RP_ID=
