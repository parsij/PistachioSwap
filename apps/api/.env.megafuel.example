# Copy these values into apps/api/.env. Never expose them through VITE_* variables.
SPONSORSHIP_BILLING_MODE=prepaid
MEGAFUEL_PREPAID_ENABLED=false
MEGAFUEL_CHAIN_ID=56

# Provider-response debugging is backend-only. Responses are redacted and truncated,
# but this should still remain false outside controlled local debugging.
DEBUG_SPONSORSHIP_PROVIDER_RESPONSES=false

# Structured route, paymaster, policy, timing, PostgreSQL-code, and stack tracing.
# Secrets, signatures, session tokens, and signed raw transactions are redacted.
DEBUG_SPONSORSHIP_TRACE=false

# Live-canary-only cleanup. When true, the XAUT live test expires only the exact
# order it created after an error, and only while it remains unsigned and unbroadcast.
EXPIRE_AFTER_ERROR=false

# EXTREMELY DANGEROUS. Whitelisted tokens already bypass third-party security and
# transfer simulation. This switch additionally bypasses live liquidity, price-age,
# and price-deviation gates. Never enable this in production.
DANGEROUSLY_BYPASS_SPONSORSHIP_TOKEN_CHECKS=false

# NodeReal private policy credentials, backend only.
# Both policies use the same NodeReal API key but MUST have different UUIDs.
MEGAFUEL_API_KEY=
MEGAFUEL_FEE_POLICY_UUID=
MEGAFUEL_ACTION_POLICY_UUID=
MEGAFUEL_PRIVATE_RPC_BASE_URL=https://open-platform-ap.nodereal.io
MEGAFUEL_USER_AGENT=PistachioWallet/1.0
# Keep MegaFuel independent from shorter quote-provider timeouts.
MEGAFUEL_REQUEST_TIMEOUT_MS=15000

# Localhost-only sponsorship token and refund management API.
# Generate at least 32 random bytes, for example: openssl rand -hex 32
SPONSORSHIP_ADMIN_TOKEN=

# The order, all three signing intents, and the post-payment grant use a
# fifteen-minute lifetime.
MEGAFUEL_ORDER_TTL_SECONDS=900
MEGAFUEL_ACTION_INTENT_TTL_SECONDS=900
MEGAFUEL_AUTH_CHALLENGE_TTL_SECONDS=300
MEGAFUEL_AUTH_SESSION_TTL_SECONDS=900

# Fee model: sponsored payment + approval + swap gas reserve x 1.5,
# plus $0.067, plus 3%. The exact fee is charged in the sell token.
MEGAFUEL_GAS_MULTIPLIER_BPS=15000
MEGAFUEL_FIXED_FEE_USD=0.067
MEGAFUEL_PLATFORM_FEE_BPS=300

# Kept only for backward-compatible config parsing. Exact prepaid mode does not
# cap the $0.067 + 3% commercial fee after the fixed-point change.
MEGAFUEL_COMMERCIAL_FEE_CAP_USD=1000000

# The settlement-safety probe quotes about $0.10 of the sell token to BNB,
# then USDT, then USDC. Sponsorship is rejected when all three targets fail.
GAS_ASSIST_MIN_SELL_USD=0.10
MEGAFUEL_MIN_GROSS_TRADE_USD=0.10
MEGAFUEL_MIN_NET_TRADE_USD=0.10
MEGAFUEL_MIN_OUTPUT_USD=0.10
MEGAFUEL_MIN_PAYMENT_TOKEN_LIQUIDITY_USD=0
MEGAFUEL_MAX_PRICE_AGE_SECONDS=300
MEGAFUEL_MAX_PRICE_DEVIATION_BPS=300

MEGAFUEL_APPROVAL_SPONSOR_ENABLED=true
MEGAFUEL_NORMAL_SWAP_SPONSOR_ENABLED=true
# Each target quote tries configured providers in this order.
# PancakeSwap is excluded until its Permit2 authorization is implemented as an exact sponsored intent.
MEGAFUEL_SPONSORED_SWAP_PROVIDERS=uniswap,0x
MEGAFUEL_APPROVAL_MODE=exact
MEGAFUEL_REJECT_UNLIMITED_APPROVAL=true
MEGAFUEL_ZEROX_SAFE_APPROVAL_TARGETS_56=0x0000000000001ff3684f28c67538d4d072c22734
MEGAFUEL_ZEROX_SETTLER_ADDRESS_56=0x00000000000004533fe15556b1e086bb1a72ceae

MEGAFUEL_MAX_PAYMENT_TRANSFER_GAS=150000
MEGAFUEL_MAX_APPROVAL_GAS=150000
MEGAFUEL_MAX_SWAP_GAS=600000

MEGAFUEL_WALLET_DAILY_ORDER_LIMIT=3
MEGAFUEL_WALLET_DAILY_GAS_USD=1
MEGAFUEL_IP_DAILY_ORDER_LIMIT=10
MEGAFUEL_GLOBAL_DAILY_ORDER_LIMIT=500
MEGAFUEL_GLOBAL_DAILY_GAS_USD=100
MEGAFUEL_WALLET_COOLDOWN_SECONDS=60
MEGAFUEL_MAX_UNPAID_PAYMENT_ATTEMPTS=2
MEGAFUEL_MAX_REPEATED_REVERTS=2
MEGAFUEL_MAX_REPEATED_EXPIRIES=3
MEGAFUEL_MAX_SIGNATURE_MISMATCHES=3
MEGAFUEL_MIN_COMMERCIAL_OVER_PAYMENT_GAS_USD=0.01
MEGAFUEL_IP_HASH_SECRET=

# Keep true until all migrations are reviewed/applied and the exact-payment,
# two-policy routing, approval, swap, recovery, refund, and live-canary checks pass.
MEGAFUEL_EMERGENCY_DISABLED=true
