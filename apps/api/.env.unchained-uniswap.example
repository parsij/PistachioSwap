# SELF-HOSTED SHAPESHIFT UNCHAINED WALLET INVENTORY
# PistachioSwap calls each configured coinstack at /api/v1/account/{wallet}.
UNCHAINED_ENABLED=true
UNCHAINED_ALLOW_INSECURE_HTTP=false
UNCHAINED_REQUEST_TIMEOUT_MS=8000

# Map EIP-155 chain IDs to your self-hosted Unchained HTTP endpoints.
# Each chain normally has its own Unchained coinstack deployment.
UNCHAINED_HTTP_URLS_JSON={"1":"https://ethereum.unchained.example","56":"https://bnb.unchained.example"}

# Individual variables may be used instead of or in addition to the JSON map.
# UNCHAINED_HTTP_URL_1=https://ethereum.unchained.example
# UNCHAINED_HTTP_URL_56=https://bnb.unchained.example

# UNISWAP PUBLIC-SUBGRAPH 24H VOLUME CATALOG
UNISWAP_TOKEN_LIST_URL=https://tokens.uniswap.org
UNISWAP_SUBGRAPH_TIMEOUT_MS=12000

# Map each chain to one or more Uniswap v3/v4 GraphQL subgraphs that expose
# tokenHourDatas. Multiple versions are aggregated. Use your own authenticated
# Graph gateway URLs when required; never place their keys in frontend env vars.
# "all chains" means every chain configured in this map.
UNISWAP_SUBGRAPH_URLS_JSON={"1":["https://gateway.thegraph.com/api/REPLACE_WITH_KEY/subgraphs/id/REPLACE_WITH_ETHEREUM_V3_ID"],"8453":["https://gateway.thegraph.com/api/REPLACE_WITH_KEY/subgraphs/id/REPLACE_WITH_BASE_V3_ID"]}
